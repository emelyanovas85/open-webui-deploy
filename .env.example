# =============================================================
# Open WebUI Configuration
# Copy this file to .env and fill in your values
# =============================================================

# --- LLM Provider ---
# OpenAI (or compatible API)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Ollama (local, default enabled)
OLLAMA_BASE_URL=http://ollama:11434

# --- Security ---
WEBUI_SECRET_KEY=change-this-to-a-random-secret-string

# --- Open WebUI settings ---
WEBUI_NAME=Open WebUI
WEBUI_AUTH=true
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=pending
# Comma-separated list of default models (leave empty = all available)
DEFAULT_MODELS=

# --- Webhook Handler (MR_Checker) ---
WEBHOOK_GITLAB_SECRET_TOKEN=your-gitlab-secret
WEBHOOK_GITHUB_SECRET_TOKEN=your-github-secret
