# openssl-legacy.cnf
# Понижаем SECLEVEL до 0 чтобы Python/requests мог работать с TLS AES256-GCM-SHA384 без ECDHE
# (используется сервером chat.ehd-zr.cbr.ru)

openssl_conf = openssl_init

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
CipherString = DEFAULT:@SECLEVEL=0
MinProtocol = TLSv1.2
