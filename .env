# =============================================================
# Open WebUI Configuration
# Скопировано из .env.example — заполнено для подключения LLM
# =============================================================

# --- LLM Provider (OpenAI-compatible API) ---
OPENAI_API_KEY=sk-09fd660cdc8640ac861fe85a16d2d2f1
OPENAI_API_BASE_URL=https://chat.ehd-zr.cbr.ru/openai

# --- Ollama (отключаем, если используем только внешний LLM) ---
OLLAMA_BASE_URL=

# --- Security ---
WEBUI_SECRET_KEY=change-this-to-a-random-secret-string

# --- Open WebUI settings ---
WEBUI_NAME=Open WebUI
WEBUI_AUTH=true
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=pending
# Модель по умолчанию
DEFAULT_MODELS=Qwen/Qwen3.5-397B-A17B-GPTQ-Int4

# --- Webhook Handler (MR_Checker) ---
WEBHOOK_GITLAB_SECRET_TOKEN=your-gitlab-secret
WEBHOOK_GITHUB_SECRET_TOKEN=your-github-secret
