# =============================================================
# Open WebUI — конфигурация
# =============================================================

# ── LLM Provider ──────────────────────────────────────────────
# Модели подключены через Pipe Function (cbr_models) с SSL-патчем.
# Здесь оставляем пустыми — иначе Open WebUI будет пытаться
# опрашивать /openai/models через свой стандартный aiohttp-клиент
# (несовместимый с SSL ЦБ РФ) — TimeoutError в логах.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
ENABLE_OPENAI_API=false

# ── Ollama (оставить пустым если не используется) ──────────────────────
OLLAMA_BASE_URL=
ENABLE_OLLAMA_API=false

# ── Security ────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-this-to-a-random-secret-string

# ── Администратор (создаётся автоматически при первом запуске) ──────────────────
WEBUI_ADMIN_EMAIL=bugbusters@cbr.ru
WEBUI_ADMIN_PASSWORD=bugbusters
WEBUI_ADMIN_NAME=bugbusters

# ── Общие настройки ──────────────────────────────────────────────────
WEBUI_NAME=Open WebUI
WEBUI_AUTH=true
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
# Модель по умолчанию — через Pipe Function id.model_id
DEFAULT_MODELS=cbr_models.Qwen/Qwen3.5-397B-A17B-GPTQ-Int4

# ── Task model (автозаголовки, теги) ──────────────────────────────────
TASK_MODEL_EXTERNAL=cbr_models.Qwen/Qwen3.5-397B-A17B-GPTQ-Int4

# ── RAG / Embeddings ────────────────────────────────────────────────
ENABLE_RAG_WEB_SEARCH=false

# ── SSL ──────────────────────────────────────────────────────────────────
OPENAI_API_VERIFY_SSL=false

# ── Прокси ─────────────────────────────────────────────────────────────────────
# ВАЖНО: два ограничения одновременно:
# 1. Docker Compose читает .env буквально — кавычки передаются внутрь контейнера
#    как часть значения. Кавычки НЕЛЬЗЯ использовать в .env.
# 2. Python (aiohttp внутри Open WebUI) НЕ поддерживает CIDR-нотацию (10.0.0.0/8)
#    в NO_PROXY — перечисляем конкретные IP явно.
NO_PROXY=localhost,127.0.0.1,10.1.5.97,10.1.5.6,10.1.26.2,chat.ehd-zr.cbr.ru
no_proxy=localhost,127.0.0.1,10.1.5.97,10.1.5.6,10.1.26.2,chat.ehd-zr.cbr.ru

# ── MCP Tool Servers (через запятую, без пробелов) ────────────────────────
# Формат: url1::name1::desc1,url2::name2::desc2
#
# ВАЖНО: URL должен содержать путь /mcp — Open WebUI НЕ добавляет его автоматически.
#
# Java MCP: Spring AI 2.0.0 + WebMVC → Streamable HTTP
#   Транспорт: WebMvcStreamableServerTransportProvider
#   Endpoint: POST /mcp
#
# GitLab MCP: zereight/gitlab-mcp → нативный Streamable HTTP
#   REMOTE_AUTHORIZATION=true — требует заголовок Authorization: Bearer <token>
#   Токен задаётся в GITLAB_MCP_TOKEN ниже и прописывается init-скриптом
#   автоматически в Open WebUI (auth_type=bearer).
MCP_SERVER_URLS=http://10.1.5.97:8086/mcp::Java MCP (:8086)::Инструменты Java-контекста на порту 8086,http://10.1.5.97:8083/mcp::GitLab MCP (:8083)::Инструменты GitLab API на порту 8083

# ── GitLab MCP: Bearer-токен для REMOTE_AUTHORIZATION=true ───────────────────
# Тот же GitLab Personal Access Token что используется в deploy-gitlab-mcp.sh
# init-openwebui.py читает эту переменную через MCP_BEARER_TOKENS:
#   MCP_BEARER_TOKENS=http://10.1.5.97:8083/mcp::<token>
# и автоматически прописывает auth_type=bearer в Open WebUI Tool Servers.
# Замените значение на реальный токен перед деплоем.
GITLAB_MCP_TOKEN=glpat-your-token-here

# ── MCP Bearer Tokens (url::token через запятую) ──────────────────────────────
# Читается init-openwebui.py для автоматической настройки auth_type=bearer.
# Формат: url_с_путём::token,url2::token2
# Должен совпадать с URL из MCP_SERVER_URLS.
MCP_BEARER_TOKENS=http://10.1.5.97:8083/mcp::${GITLAB_MCP_TOKEN}

# ── Адрес Open WebUI внутри Docker-сети (для init-скрипта) ─────────────────────
WEBUI_BASE_URL=http://open-webui:8080

# ── Webhook Handler (MR_Checker) ────────────────────────────────────────────────
WEBHOOK_GITLAB_SECRET_TOKEN=your-gitlab-secret
WEBHOOK_GITHUB_SECRET_TOKEN=your-github-secret
