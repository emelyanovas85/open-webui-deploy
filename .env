# =============================================================
# Open WebUI — конфигурация
# =============================================================

# ── LLM Provider ──────────────────────────────────────────────────
# Модели подключены через Pipe Function (cbr_models) с SSL-патчем.
# Здесь оставляем пустыми — иначе Open WebUI будет пытаться
# опрашивать /openai/models через свой стандартный aiohttp-клиент
# (несовместимый с SSL ЦБ РФ) — TimeoutError в логах.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=
ENABLE_OPENAI_API=false

# ── Ollama (оставить пустым если не используется) ─────────────────────
OLLAMA_BASE_URL=
ENABLE_OLLAMA_API=false

# ── Security ────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-this-to-a-random-secret-string

# ── Администратор (создаётся автоматически при первом запуске) ──────────────
WEBUI_ADMIN_EMAIL=bugbusters@cbr.ru
WEBUI_ADMIN_PASSWORD=bugbusters
WEBUI_ADMIN_NAME=bugbusters

# ── Общие настройки ──────────────────────────────────────────────────
WEBUI_NAME=Open WebUI
WEBUI_AUTH=true
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
# Модель по умолчанию — через Pipe Function id.model_id
DEFAULT_MODELS=cbr_models.Qwen/Qwen3.5-397B-A17B-GPTQ-Int4

# ── Task model (автозаголовки, теги) ──────────────────────────────────────
TASK_MODEL_EXTERNAL=cbr_models.Qwen/Qwen3.5-397B-A17B-GPTQ-Int4

# ── RAG / Embeddings ───────────────────────────────────────────────
# RAG_EMBEDDING_ENGINE=openai здесь не используется: Open WebUI будет пытаться
# инициализировать openai-клиент для embeddings и блокировать загрузку моделей.
# Оставляем по умолчанию (sentence-transformers локально).
ENABLE_RAG_WEB_SEARCH=false

# ── SSL ────────────────────────────────────────────────────────────────
OPENAI_API_VERIFY_SSL=false

# ── Прокси ──────────────────────────────────────────────────────────────────
NO_PROXY=localhost,127.0.0.1,10.0.0.0/8,chat.ehd-zr.cbr.ru
no_proxy=localhost,127.0.0.1,10.0.0.0/8,chat.ehd-zr.cbr.ru

# ── MCP Tool Servers (через запятую, без пробелов) ───────────────────────────
# Формат: url1::name1::desc1,url2::name2::desc2
MCP_SERVER_URLS=http://10.1.5.97:8086/sse::☕ Java MCP (:°8086)::Инструменты Java-контекста на порту 8086,http://10.1.5.97:8083/sse::🦊 GitLab MCP (:°8083)::Инструменты GitLab API на порту 8083

# ── Адрес Open WebUI внутри Docker-сети (для init-скрипта) ───────────────────
WEBUI_BASE_URL=http://open-webui:8080

# ── Webhook Handler (MR_Checker) ────────────────────────────────────────────────
WEBHOOK_GITLAB_SECRET_TOKEN=your-gitlab-secret
WEBHOOK_GITHUB_SECRET_TOKEN=your-github-secret
